# Copy to contracts/.env and fill in. NEVER commit the real .env.

# Mantle Sepolia Testnet (chainId 5003, gas token MNT)
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz

# Deployer key — use a throwaway testnet key, fund it from the faucet:
# https://faucet.sepolia.mantle.xyz
PRIVATE_KEY=0x...

# Optional: for `forge verify-contract` on MantleScan
MANTLESCAN_API_KEY=

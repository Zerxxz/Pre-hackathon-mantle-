# Copy to harness/.env and fill in. All four are required to anchor on-chain;
# omit them to run a local dry run (prints the report without anchoring).
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz
BENCHMARK_REGISTRY_ADDRESS=0x...   # deployed BenchmarkRegistry (see root README)
CONTROLLER_PRIVATE_KEY=0x...       # MUST be the agent's controller (anchor is gated)
AGENT_ID=1                         # the agentId minted by AgentRegistry

# Copy to orchestrator/.env and fill in.
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz

# The account that creates AND settles matches (must be the match orchestrator).
ORCHESTRATOR_PRIVATE_KEY=0x...
MATCH_MANAGER_ADDRESS=0x...

# Competitors for the demo match (parallel CSV lists, same length).
PLAYERS=0xAgentAddr,0xHumanAddr
NATURES=AI,Human                # AI | Human per player
LEADERBOARD_IDS=1,1000          # agentId for agents; any id for humans

# Match params
ROUNDS=5
COMMIT_WINDOW=45                # seconds players have to commit
REVEAL_WINDOW=45                # seconds players have to reveal

# Copy to agent/.env and fill in.
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz
AGENT_PRIVATE_KEY=0x...           # key that signs the agent's actions
MATCH_MANAGER_ADDRESS=0x...       # deployed MatchManager (see root README)
AGENT_REGISTRY_ADDRESS=0x...      # deployed AgentRegistry

# Optional: play a single existing match instead of watching for new ones.
# MATCH_ID=1

# Optional: real LLM policy. If LLM_API_KEY is unset, the agent uses a
# transparent heuristic. Any OpenAI-compatible endpoint works.
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
